{
   "id": "pf2e-aztecs-lock-n-load",
   "title": "PF2e Aztec's Lock & Load",
   "description": "Add SFX to your guns!",
   "version": "#{VERSION}#",
   "compatibility": {
      "minimum": "13",
      "verified": "14"
   },
   "esmodules": ["src/module.mjs"],
   "styles": ["styles/module.css"],
   "languages": [
      {
         "lang": "en",
         "name": "English",
         "path": "lang/en.json"
      },
      {
         "lang": "ru",
         "name": "Russian",
         "path": "lang/ru.json"
      }
   ],
   "authors": [
      {
         "name": "Aztec",
         "discord": "two.bears.high.fiving"
      }
   ],
   "url": "#{URL}#",
   "manifest": "#{MANIFEST}#",
   "download": "#{DOWNLOAD}#",
   "socket": true,
   "relationships": {
      "requires": [
         {
            "id": "socketlib",
            "type": "module"
         }
      ]
   }
}
